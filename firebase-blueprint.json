{
  "entities": {
    "invoice": {
      "title": "Invoice",
      "description": "Electronic invoice data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "contactId": { "type": "string", "description": "Link to a specific contact" },
        "invoiceTitle": { "type": "string" },
        "businessActivity": { "type": "string" },
        "serviceProvider": { "type": "string" },
        "clientName": { "type": "string" },
        "logo": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "description": { "type": "string" },
              "price": { "type": "number" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["paid", "pending", "overdue"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "savedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items"]
    },
    "contact": {
      "title": "Contact",
      "description": "Customer or Person information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "businessId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "notes": { "type": "string" },
        "totalBalance": { "type": "number", "description": "Current balance for this person" },
        "totalPaid": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name"]
    },
    "payment": {
      "title": "Payment",
      "description": "Record of money received",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "contactId": { "type": "string" },
        "invoiceId": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string", "enum": ["cash", "bank", "card", "other"] },
        "date": { "type": "string", "format": "date-time" },
        "note": { "type": "string" }
      }
    },
    "expense": {
      "title": "Expense",
      "description": "Business expenditures",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "businessId": { "type": "string" },
        "category": { "type": "string", "description": "Rent, Materials, Shipping, etc." },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" }
      }
    },
    "product": {
      "title": "Product",
      "description": "Inventory items",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "quantity": { "type": "number" },
        "price": { "type": "number" },
        "cost": { "type": "number", "description": "Purchase cost for profit calculation" }
      }
    },
    "businessInfo": {
      "title": "Business Info",
      "description": "User's business profile details",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "logo": { "type": "string" },
        "activityIndex": { "type": "number" },
        "customActivity": { "type": "string" },
        "invoicePrefix": { "type": "string", "description": "Unique 6-letter prefix for invoice numbering" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId"]
    }
  },
  "firestore": {
    "invoices": {
      "schema": "invoice",
      "description": "Collection of saved invoices"
    },
    "clients": {
      "schema": "contact",
      "description": "Business clients and customers"
    },
    "payments": {
      "schema": "payment",
      "description": "Payment history"
    },
    "expenses": {
      "schema": "expense",
      "description": "Business expenses"
    },
    "products": {
      "schema": "product",
      "description": "Inventory and products"
    },
    "businessInfo": {
      "schema": "businessInfo",
      "description": "User business profiles"
    }
  }
}
