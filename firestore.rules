rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidInvoice(data) {
      return data.userId == request.auth.uid &&
             data.items is list &&
             data.items.size() <= 100 &&
             (!('contactId' in data) || (data.contactId == null || data.contactId == "" || isValidId(data.contactId)));
    }

    function isValidContact(data) {
      return data.userId == request.auth.uid &&
             data.name is string &&
             data.name.size() > 0 && 
             data.name.size() <= 100;
    }

    function isValidPayment(data) {
      return data.userId == request.auth.uid &&
             data.amount is number &&
             data.amount >= 0 &&
             isValidId(data.contactId);
    }

    function isValidExpense(data) {
      return data.userId == request.auth.uid &&
             data.amount is number &&
             data.amount >= 0;
    }

    function isValidProduct(data) {
      return data.userId == request.auth.uid &&
             data.name is string &&
             data.price is number;
    }

    function isValidBusinessInfo(data) {
      return data.userId == request.auth.uid &&
             (!('name' in data) || data.name is string) &&
             (!('phone' in data) || data.phone is string);
    }

    match /invoices/{invoiceId} {
      allow get: if isOwner(resource.data.userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidInvoice(incoming());
      allow update: if isOwner(resource.data.userId) && isValidInvoice(incoming());
      allow delete: if isOwner(resource.data.userId);
    }

    match /clients/{clientId} {
      allow get: if isOwner(resource.data.userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidContact(incoming());
      allow update: if isOwner(resource.data.userId) && isValidContact(incoming());
      allow delete: if isOwner(resource.data.userId);
    }

    match /payments/{paymentId} {
      allow get: if isOwner(resource.data.userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidPayment(incoming());
      allow update: if isOwner(resource.data.userId) && isValidPayment(incoming());
      allow delete: if isOwner(resource.data.userId);
    }

    match /expenses/{expenseId} {
      allow get: if isOwner(resource.data.userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidExpense(incoming());
      allow update: if isOwner(resource.data.userId) && isValidExpense(incoming());
      allow delete: if isOwner(resource.data.userId);
    }

    match /products/{productId} {
      allow get: if isOwner(resource.data.userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidProduct(incoming());
      allow update: if isOwner(resource.data.userId) && isValidProduct(incoming());
      allow delete: if isOwner(resource.data.userId);
    }

    match /businessInfo/{userId} {
      allow get: if isOwner(userId);
      // Even though it's set by userId, it's a collection, so list still applies for queries if used
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isOwner(userId) && isValidBusinessInfo(incoming());
      allow update: if isOwner(userId) && isValidBusinessInfo(incoming());
      allow delete: if isOwner(userId);
    }
  }
}
