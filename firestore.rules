rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidInvoice(data) {
      return data.userId == request.auth.uid &&
             data.items is list &&
             data.items.size() <= 100 &&
             (!('contactId' in data) || (data.contactId == null || data.contactId == "" || isValidId(data.contactId)));
    }

    function isValidContact(data) {
      return data.userId == request.auth.uid &&
             data.name is string &&
             data.name.size() > 0 && 
             data.name.size() <= 100;
    }

    function isValidPayment(data) {
      return data.userId == request.auth.uid &&
             data.amount is number &&
             data.amount >= 0 &&
             isValidId(data.contactId);
    }

    function isValidExpense(data) {
      return data.userId == request.auth.uid &&
             data.amount is number &&
             data.amount >= 0;
    }

    function isValidProduct(data) {
      return data.userId == request.auth.uid &&
             data.name is string &&
             data.price is number;
    }

    function isValidBusinessInfo(data) {
      return data.userId == request.auth.uid &&
             (!('name' in data) || data.name is string) &&
             (!('phone' in data) || data.phone is string);
    }

    function isApproved() {
      return get(/databases/$(database)/documents/users_profiles/$(request.auth.uid)).data.isApproved == true;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == 'mrmostafash187@gmail.com';
    }

    match /users_profiles/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
      allow list: if isSuperAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSuperAdmin() || (isSignedIn() && request.auth.uid == userId && !incoming().diff(existing()).affectedKeys().hasAny(['isApproved']));
    }

    match /invoices/{invoiceId} {
      allow get: if isOwner(resource.data.userId);
      allow list: if isApproved() && resource.data.userId == request.auth.uid;
      allow create: if isApproved() && isValidInvoice(incoming());
      allow update: if isOwner(resource.data.userId) && isValidInvoice(incoming());
      allow delete: if isOwner(resource.data.userId);
    }

    match /clients/{clientId} {
      allow get: if isOwner(resource.data.userId);
      allow list: if isApproved() && resource.data.userId == request.auth.uid;
      allow create: if isApproved() && isValidContact(incoming());
      allow update: if isOwner(resource.data.userId) && isValidContact(incoming());
      allow delete: if isOwner(resource.data.userId);
    }

    match /payments/{paymentId} {
      allow get: if isOwner(resource.data.userId);
      allow list: if isApproved() && resource.data.userId == request.auth.uid;
      allow create: if isApproved() && isValidPayment(incoming());
      allow update: if isOwner(resource.data.userId) && isValidPayment(incoming());
      allow delete: if isOwner(resource.data.userId);
    }

    match /expenses/{expenseId} {
      allow get: if isOwner(resource.data.userId);
      allow list: if isApproved() && resource.data.userId == request.auth.uid;
      allow create: if isApproved() && isValidExpense(incoming());
      allow update: if isOwner(resource.data.userId) && isValidExpense(incoming());
      allow delete: if isOwner(resource.data.userId);
    }

    match /products/{productId} {
      allow get: if isOwner(resource.data.userId);
      allow list: if isApproved() && resource.data.userId == request.auth.uid;
      allow create: if isApproved() && isValidProduct(incoming());
      allow update: if isOwner(resource.data.userId) && isValidProduct(incoming());
      allow delete: if isOwner(resource.data.userId);
    }

    match /businessInfo/{userId} {
      allow get: if isOwner(userId);
      // Even though it's set by userId, it's a collection, so list still applies for queries if used
      allow list: if isApproved() && resource.data.userId == request.auth.uid;
      allow create: if isOwner(userId) && isValidBusinessInfo(incoming());
      allow update: if isOwner(userId) && isValidBusinessInfo(incoming());
      allow delete: if isOwner(userId);
    }
  }
}
